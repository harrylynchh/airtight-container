# Client (Vite) environment variables.
# Vite only exposes vars prefixed with VITE_ to the browser bundle.

# Google Maps JavaScript API key for Places Autocomplete address autofill on
# the client form. Optional: when unset, the address fields fall back to plain
# manual entry (no autocomplete, no console errors). Enable the "Maps
# JavaScript API" and "Places API" for this key in Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=
