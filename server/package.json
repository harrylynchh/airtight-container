{
  "name": "server",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx server.js",
    "dev": "tsx watch server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:introspect": "drizzle-kit introspect",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/client-textract": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "better-auth": "^1.2.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "puppeteer": "^24.43.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^3.4.0",
    "tsx": "^4.19.0",
    "twilio": "^6.0.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
